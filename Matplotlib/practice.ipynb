    "import numpy\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "x = numpy.random.normal(5.0, 1.0, 1000)\n",
    "y = numpy.random.normal(10.0, 2.0, 1000)\n",
    "\n",
    "x_m = numpy.mean(x)\n",
    "y_m = numpy.mean(y)\n",
    "\n",
    "print(x_m, y_m)\n",
    "\n",
    "plt.scatter(x, y)\n",
    "plt.scatter(x_m, y_m, color = 'red', s=50)\n",
    "plt.show()"
   ]
